{
  "id": "gsd-oc",
  "name": "GSD-OC",
  "description": "GSD lifecycle orchestration for OpenClaw — native, no Claude Code.",
  "version": "0.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "engageMode": {
        "type": "string",
        "enum": [
          "workspace",
          "intent",
          "off"
        ],
        "default": "workspace",
        "description": "When to auto-engage GSD: workspace (cwd+intent), intent (intent anywhere), off."
      },
      "codingRoots": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [],
        "description": "Extra coding-workspace dirs (~ and $VAR ok); multiple allowed."
      },
      "includeDefaultRoot": {
        "type": "boolean",
        "default": true,
        "description": "Include the built-in $HOME/codeWS default root."
      },
      "workerAgent": {
        "type": "string",
        "default": "dev",
        "description": "Allowlisted base agent hosting GSD personas when driving."
      },
      "autoEngage": {
        "type": "boolean",
        "default": true,
        "description": "Master switch for auto-engage."
      },
      "disabled": {
        "type": "boolean",
        "default": false,
        "description": "Disable engagement entirely."
      }
    }
  },
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "gsd_orchestrate",
      "gsd_retrieve",
      "gsd_settings",
      "gsd_state",
      "gsd_workstream",
      "gsd_verify",
      "gsd_command",
      "gsd_workflow",
      "gsd_project",
      "gsd_quality",
      "gsd_context",
      "gsd_manage",
      "gsd_ideate"
    ]
  }
}
