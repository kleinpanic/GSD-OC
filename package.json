{
  "name": "gsd-oc",
  "version": "0.0.0",
  "description": "GSD lifecycle orchestration for OpenClaw — native, no Claude Code.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-artifacts.mjs",
    "build:corpus": "node --experimental-strip-types scripts/build-corpus.ts",
    "build:vectors": "node --experimental-strip-types scripts/build-vectors.ts",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/test/*.test.js\""
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "2026.6.8",
    "typescript": "^5.9.0"
  },
  "license": "MIT"
}
